{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": ["http://localhost:4200"]
  },
  "Jwt": {
    "Issuer": "logistique-les-lions-api",
    "Audience": "logistique-les-lions-client",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 30
  },
  "Frontend": {
    "Url": "http://localhost:4200"
  },
  "Storage": {
    "Provider": "local",
    "LocalPath": "uploads",
    "MaxFileSizeBytes": 10485760,
    "AllowedFormats": ["image/jpeg", "image/png", "image/webp"]
  },
  "RateLimit": {
    "GeneralPermitLimit": 100,
    "GeneralWindowMinutes": 1,
    "AuthPermitLimit": 10,
    "AuthWindowMinutes": 5
  },
  "Webhooks": {
    "Enabled": false,
    "Url": "",
    "Secret": ""
  },
  "StaleProcess": {
    "Enabled": true,
    "DaysThreshold": 7,
    "CheckIntervalHours": 24,
    "AdminEmail": ""
  },
  "Anthropic": {
    "ApiKey": "",
    "BaseUrl": "https://api.anthropic.com",
    "Model": "claude-sonnet-4-6",
    "Version": "2023-06-01",
    "MaxTokens": 1024
  },
  "Email": {
    "Provider": "Console",
    "FromAddress": "no-reply@logistiqueleslions.com",
    "FromName": "Logistique Les Lions",
    "Resend": {
      "ApiKey": "",
      "BaseUrl": "https://api.resend.com"
    }
  }
}
